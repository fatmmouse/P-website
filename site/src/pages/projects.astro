---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
---
<Base title="作品 · HARRY 个人连载志" description="harry 的可交互作品页，施工中。">
  <main class="page">
    <section class="panel site">
      <span class="no">作品</span>
      <span class="boom">咣当 咣当</span>
      <h1>这一页还在施工。</h1>
      <p>可交互的小作品正在路上。做出来第一时间挂这里——在那之前，<a href={`${base}#serial`}>先去看连载</a>。</p>
      <div class="progress"><i></i><span>23%</span></div>
    </section>
  </main>
</Base>

<style>
.page { margin-top: 34px; display: grid; place-items: center; }
.site {
  --r: -.5deg;
  transform: rotate(var(--r));
  padding: 56px 48px;
  text-align: center;
  max-width: 560px;
  background: var(--paper-deep);
}
.boom {
  display: block;
  font-family: var(--font-display);
  font-size: clamp(34px, 5vw, 50px);
  color: var(--red);
  text-shadow: 3px 3px 0 var(--yellow);
  animation: wiggle 1.3s ease-in-out infinite;
  margin-bottom: 18px;
}
@keyframes wiggle {
  0%, 100% { transform: rotate(-1.8deg); }
  50% { transform: rotate(1.8deg) scale(1.04); }
}
.site h1 { font-family: var(--font-display); font-size: 28px; margin-bottom: 12px; }
.site p { font-size: 15.5px; line-height: 2; }
.site a { color: var(--blue); text-decoration-thickness: 2px; }
.progress {
  width: 220px; height: 22px;
  border: 3px solid var(--ink);
  background: #fff;
  position: relative;
  margin: 22px auto 0;
}
.progress i {
  position: absolute; inset: 2px;
  width: 23%;
  background: repeating-linear-gradient(-45deg, var(--red) 0 8px, #ff7a5c 8px 16px);
  background-size: 23px 23px;
  animation: crawl 1.2s linear infinite;
}
@keyframes crawl { to { background-position: 23px 0; } }
.progress span {
  position: absolute;
  right: 7px; top: 50%;
  transform: translateY(-50%);
  font-family: var(--font-display);
  font-size: 13px;
}
</style>
